{
  "name": "@savoro/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.mjs --format=esm --external:@node-rs/argon2 --external:@libsql/client",
    "start": "node dist/index.mjs",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@hono/node-server": "^1.19.11",
    "@libsql/client": "^0.17.0",
    "@node-rs/argon2": "^2.0.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@savoro/ai": "*",
    "@savoro/db": "*",
    "@savoro/food-data": "^0.0.0",
    "ai": "^6.0.116",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "jose": "^6.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
